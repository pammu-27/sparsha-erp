<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>@ViewData["Title"] - Sparsha ERP</title>

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>

/* ===== BODY ===== */
body{
background:#f4f6f9;
font-family:Segoe UI;
margin:0;
}

/* ===== SIDEBAR ===== */
.sidebar{
position:fixed;
top:0;
left:0;
height:100vh;
width:220px;
background:linear-gradient(180deg,#041f60,#0a2c84);
color:white;
display:flex;
flex-direction:column;
z-index:1000;
transition:0.3s;
}

/* ===== LOGO ===== */
.sidebar-logo{
padding:18px;
font-size:18px;
font-weight:700;
text-align:center;
border-bottom:1px solid rgba(255,255,255,0.1);
}

/* ===== MENU ===== */
.sidebar-menu{
flex:1;
padding-top:10px;
}

.sidebar-menu a{
display:flex;
align-items:center;
gap:12px;
padding:12px 18px;
color:#e0e6ff;
text-decoration:none;
font-size:14px;
border-radius:8px;
margin:4px 10px;
transition:0.2s;
}

.sidebar-menu a:hover{
background:rgba(255,255,255,0.15);
}

.sidebar-menu a.active{
background:rgba(255,255,255,0.2);
color:white;
}

/* ===== ICON ===== */
.sidebar-menu i{
font-size:18px;
}

/* ===== USER PANEL ===== */
.sidebar-user{
padding:15px;
border-top:1px solid rgba(255,255,255,0.1);
text-align:center;
margin-top:auto;
}

/* ===== HEADER ===== */
.header{
position:fixed;
top:0;
left:220px;
right:0;
height:60px;
background:white;
display:flex;
align-items:center;
justify-content:space-between;
padding:0 20px;
box-shadow:0 2px 8px rgba(0,0,0,0.05);
z-index:999;
}

/* ===== MAIN ===== */
.main{
margin-left:220px;
padding:80px 20px 20px;
}

/* ===== MOBILE ===== */
@@media(max-width:768px){

.sidebar{
left:-220px;
}

.sidebar.show{
left:0;
}

.header{
left:0;
}

.main{
margin-left:0;
padding-top:80px;
}

}

</style>

</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">

<div class="sidebar-logo">
Sparsha ERP
</div>

<div class="sidebar-menu">

<a asp-controller="Home" asp-action="Index">
<i class="bi bi-speedometer2"></i>
Dashboard
</a>

<a asp-controller="Clients" asp-action="Index">
<i class="bi bi-people"></i>
Clients
</a>

<a asp-controller="Quotations" asp-action="Index">
<i class="bi bi-receipt"></i>
Quotations
</a>

<a asp-controller="Bills" asp-action="Index">
<i class="bi bi-cash-stack"></i>
Bills / Invoices
</a>

<hr class="text-white opacity-25">

<a asp-controller="Settings" asp-action="Index">
<i class="bi bi-gear"></i>
Settings
</a>

<a asp-controller="AuditLogs" asp-action="Index">
<i class="bi bi-bar-chart"></i>
Audit Reports
</a>

<a asp-controller="Auth" asp-action="Logout">
<i class="bi bi-box-arrow-right"></i>
Logout
</a>

</div>

<div class="sidebar-user">
<strong>@Context.Session.GetString("AdminName")</strong>
<small class="text-light opacity-75 d-block">
@Context.Session.GetString("Role")
</small>
</div>

</div>

<!-- HEADER -->
<div class="header">

<button class="btn btn-primary d-md-none" onclick="toggleSidebar()">
<i class="bi bi-list"></i>
</button>

<strong>@ViewData["Title"]</strong>

<div>
<i class="bi bi-person-circle fs-4"></i>
</div>

</div>

<!-- MAIN -->
<div class="main">

@RenderBody()

<!-- FOOTER -->
<div style="
text-align:center;
margin-top:40px;
padding:14px;
font-size:13px;
color:#6b7280;
border-top:1px solid #e5e7eb;
">
© 2026 SparshaERP | Developed by 
<span style="color:#0476d0;font-weight:600;">Pramod</span>
</div>

</div>

<script>
function toggleSidebar(){
document.getElementById("sidebar").classList.toggle("show");
}
</script>

</body>
</html>