<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>@ViewData["Title"] - Sparsha ERP</title>

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<!-- Icons -->
<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>

/* ===== BODY ===== */

body{
background:#f4f6f9;
font-family:Segoe UI;
}

/* ===== SIDEBAR ===== */

.sidebar{
position:fixed;
top:0;
left:0;
height:100vh;
width:250px;
background:linear-gradient(180deg,#041f60,#0a2c84);
color:white;
display:flex;
flex-direction:column;
}

/* ===== LOGO ===== */

.sidebar-logo{
padding:20px;
font-size:20px;
font-weight:700;
text-align:center;
border-bottom:1px solid rgba(255,255,255,0.1);
}

/* ===== MENU ===== */

.sidebar-menu{
flex:1;
padding-top:10px;
}

.sidebar-menu a{
display:flex;
align-items:center;
gap:12px;
padding:12px 20px;
color:#e0e6ff;
text-decoration:none;
font-size:15px;
transition:0.2s;
}

.sidebar-menu a:hover{
background:#0476d0;
color:white;
}

.sidebar-menu a.active{
background:#0476d0;
}

/* ===== ICON ===== */

.sidebar-menu i{
font-size:18px;
}

/* ===== USER PANEL ===== */

.sidebar-user{
padding:15px;
border-top:1px solid rgba(255,255,255,0.1);
}

.sidebar-user strong{
display:block;
}

/* ===== MAIN CONTENT ===== */

.main{
margin-left:250px;
padding:25px;
}

/* ===== MOBILE ===== */

@@media(max-width:768px){

.sidebar{
left:-250px;
transition:0.3s;
}

.sidebar.show{
left:0;
}

.main{
margin-left:0;
}

}

</style>

</head>

<body>

<!-- ================= SIDEBAR ================= -->

<div class="sidebar" id="sidebar">

<div class="sidebar-logo">
Sparsha ERP
</div>

<div class="sidebar-menu">

<a asp-controller="Home" asp-action="Index">
<i class="bi bi-speedometer2"></i>
Dashboard
</a>

<a asp-controller="Clients" asp-action="Index">
<i class="bi bi-people"></i>
Clients
</a>

<a asp-controller="Quotations" asp-action="Index">
<i class="bi bi-receipt"></i>
Quotations
</a>

<a asp-controller="Bills" asp-action="Index">
<i class="bi bi-cash-stack"></i>
Bills / Invoices
</a>

<hr class="text-white opacity-25">

<a asp-controller="Settings" asp-action="Index">
<i class="bi bi-gear"></i>
Settings
</a>

<a asp-controller="AuditLogs" asp-action="Index">
<i class="bi bi-bar-chart"></i>
Audit Reports
</a>

<a asp-controller="Auth" asp-action="Logout">
<i class="bi bi-box-arrow-right"></i>
Logout
</a>

</div>

<div class="sidebar-user">

<strong>@Context.Session.GetString("AdminName")</strong>

<small class="text-light opacity-75">
@Context.Session.GetString("Role")
</small>

</div>

</div>

<!-- ================= MAIN ================= -->

<div class="main">

<button class="btn btn-primary d-md-none mb-3"
onclick="toggleSidebar()">
<i class="bi bi-list"></i> Menu
</button>

@RenderBody()

</div>

<script>

function toggleSidebar(){
document.getElementById("sidebar").classList.toggle("show");
}

</script>

</body>
</html>